# -------- Necessary edits --------
# Your domain, pointing to your server IP
DOMAIN=
# Your local domain. For Example 192.168.1.50
SERVER_IP=
# `htpasswd -nB admin | cut -d ":" --fields 2`
PORTAINER_ADMIN_PASSWORD=
# `docker compose exec vw /vaultwarden hash`
VW_ADMIN_TOKEN=
# Your email for Let's Encrypt challenges
LETSENCRYPT_EMAIL=
# Find the good one with `ls /dev/serial/by-id/`
ZIGBEE_USB=
SIMCOM_DONGLE=
# Push details. Follow steps here https://github.com/dani-garcia/vaultwarden/wiki/Enabling-Mobile-Client-push-notification
PUSH_INSTALLATION_ID=
PUSH_INSTALLATION_KEY=
# Generate your OVH API keys here https://eu.api.ovh.com/createApp/
# Allow POST and DELETE for /domain/zone/* and 
OVH_APPLICATION_KEY=
OVH_APPLICATION_SECRET=
OVH_CONSUMER_KEY=
# RTSP camera credentials
FRIGATE_TAPO_C200_USER=
FRIGATE_TAPO_C200_PASSWORD=
FRIGATE_TAPO_C200_CLOUD_PASSWORD=
FRIGATE_TAPO_C200_IP=
# GRDF credentials
GRDF_USERNAME=
GRDF_PASSWORD=
GRDF_PCE_IDENTIFIER=
# MQTT credentials for authenticated access on port 8883 (local network)
MQTT_LAN_USER=
# Plaintext password — local access only (port 8883, LAN), low security risk
MQTT_LAN_PASSWORD=
# Generate with : docker run --rm authelia/authelia:latest authelia crypto rand --length 64 --charset alphanumeric
AUTHELIA_STORAGE_ENCRYPTION_KEY=
# (Optional) YouTube Live stream key — see README
YOUTUBE_STREAM_KEY=

# -------- Optionnal edits --------
# Internal docker network IP
SUBNET_IP=172.50.0.0/16
# Docker bridge gateway IP (first IP of SUBNET_IP, used to bind internal services)
DOCKER_GATEWAY_IP=172.50.0.1
TRAEFIK_DYNAMIC_CONF=/etc/traefik/traefik_dynamic.yml
OLLAMA_CPUS=3.0
OLLAMA_MEM=10G
YOUTUBE_STREAM_LOG_FILE=/tmp/youtube_stream.log
